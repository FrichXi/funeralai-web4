GEMINI_API_KEY=your-gemini-api-key
# Multi-key rotation (optional, comma-separated):
# GEMINI_API_KEYS=key1,key2,key3

# OpenAI-compatible providers for local agents
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Alibaba Cloud Model Studio / DashScope, China (Beijing) region
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Kimi / Moonshot, China platform
MOONSHOT_API_KEY=your-moonshot-api-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_CODE_MODEL=kimi-k2.7-code

# DeepSeek (official)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FAST_MODEL=deepseek-v4-flash

# DeepSeek via SiliconFlow (blocked: needs identity verification)
# DEEPSEEK_SILICONFLOW_API_KEY=your-siliconflow-api-key
# DEEPSEEK_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# DEEPSEEK_SILICONFLOW_MODEL=deepseek-reasoner

# Anthropic / Claude (2 working keys)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_KEY_2=your-anthropic-api-key-2
# Available models: claude-fable-5, claude-opus-4-8, claude-opus-4-7, claude-sonnet-4-6, claude-opus-4-6,
#   claude-opus-4-5-20251101, claude-haiku-4-5-20251001, claude-sonnet-4-5-20250929,
#   claude-opus-4-1-20250805, claude-opus-4-20250514, claude-sonnet-4-20250514

# HTTP proxy (optional, for regions that need it):
# HTTPS_PROXY=http://127.0.0.1:7890
